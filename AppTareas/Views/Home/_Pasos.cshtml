<label><i class="bi bi-check-square"></i> Pasos de la tarea</label>

<button class="btn btn-secondary btn-sm" onclick="clickAgregarPasos()">
    <i class="bi bi-plus"></i>
</button>

<div id="reordenable-pasos" data-bind="foreach: pasos">
    <div class="mt-2">
        <div class="row">
            <div class="col-1">
                <input type="checkbox" class="form-check-input" name="chbPaso"
                       data-bind="checked: realizado,  click: ClickCheckboxPaso, attr:{'data-id': id}" />
            </div>
            <div class="col-11">
                <span style="cursor: pointer"
                      data-bind="text: descripcion, hidden: modoEdit, css: {'text-decoration-line-through': realizado}, click: ClickDescripcionPaso,"></span>

                <textarea name="txtPasoDescripcion" class="form-control"
                          placeholder="Agregue una descripción"
                          data-bind="{value: descripcion, visible: modoEdit}"></textarea>

                <div class="mt-2" data-bind="{visible: modoEdit}">
                    <button class="btn btn-primary" data-bind="{click: ClickSalvarPaso}">
                        Salvar
                    </button>
                    <button class="btn btn-secondary" data-bind="{click: ClickCancelarPaso}">
                        Cancelar
                    </button>
                    <button class="btn btn-danger" data-bind="{hidden: esNuevo,
                            click: ClickBorrarPaso}">
                        Borrar
                    </button>
                </div>
              
            </div>
        </div>
    </div>
</div>