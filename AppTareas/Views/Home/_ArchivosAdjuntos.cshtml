﻿<label><i class="bi bi-paperclip"></i> Archivos adjuntos</label>

<button class="btn btn-secondary btn-sm" onclick="ClickAgregarArchivoAdjunto()"><i class="bi bi-plus"></i></button>

<input type="file"
       onchange="SeleccionArchivoTarea(event)"
       id="archivoATarea" multiple style="display: none" />

<div id="reordenable-adjuntos" data-bind="foreach: archivoAdjuntos">
    <div>
        <div style="cursor: pointer" class="fw-bold" data-bind="text: titulo,
hidden: modoEdit, click: ClickTituloArchivoAdjunto"></div>

        <div data-bind="visible: modoEdit, event: {focusout: FocusoutTituloArchivoAdjunto}">
            <input name="txtArchivoAdjuntoTitulo" type="text" class="form-control"
                   data-bind="value: titulo, attr:{'data-id': id}" />
        </div>

        <div>
            Agregado <span data-bind="text: publicado"></span> -
            <span class="fw-bold" style="cursor: pointer"
                  data-bind="click: ClickBorrarArchivoAdjunto">Borrar</span> -
            <span class="fw-bold"
                  data-bind="click: ClickDescargarArchivoAdjunto"
                  style="cursor: pointer">Descargar</span>
        </div>
    </div>
</div>